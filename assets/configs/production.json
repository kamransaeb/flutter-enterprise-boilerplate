{
    "app": {
      "name": "Enterprise App",
      "version": "1.0.0",
      "buildNumber": "1"
    },
    "api": {
      "baseUrl": "https://api.enterprise.com/api/v1",
      "timeout": 30,
      "enableLogging": false
    },
    "firebase": {
      "enabled": true,
      "analyticsEnabled": true,
      "crashlyticsEnabled": true,
      "performanceEnabled": true
    },
    "features": {
      "analytics": true,
      "crashReporting": true,
      "deepLinking": true,
      "pushNotifications": true,
      "biometricAuth": true
    },
    "debug": {
      "showDebugBanner": false,
      "enableLogging": false,
      "enableInspector": false,
      "mockApiResponses": false
    }
  }