APP_NAME="Flutter Enterprise Boilerplate (Dev)"
APP_SUFFIX=.dev
APP_VERSION=1.0.0
APP_BUILD_NUMBER=1
API_BASE_URL=https://dev.api.myapp.com
API_TIMEOUT=30000
ENABLE_LOGGING=true
ENABLE_ANALYTICS=false
ENABLE_CRASHLYTICS=false
SENTRY_DSN=
FIREBASE_OPTIONS_FILE=lib/firebase_options_dev.dart

# Cache (shorter stale / smaller caps for dev; matches AppConfig.fromEnv)
CACHE_STALE_PERIOD=3
CACHE_MAX_SIZE=52428800
CACHE_MAX_OBJECTS=500
CACHE_CLEANUP_INTERVAL=12